<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane"
			xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.TransferController"
            prefWidth="1200"
            prefHeight="700">

    <top>
        <HBox alignment="CENTER"
              style="-fx-padding: 15; -fx-background-color: #f5f5f5;">
            <Label text="Fund Transfer"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20"
              style="-fx-padding: 30;">

            <TextField fx:id="txtTargetAccount"
                       promptText="Enter Target Account ID"
                       prefWidth="250"/>

            <TextField fx:id="txtAmount"
                       promptText="Enter Amount"
                       prefWidth="250"/>

            <Button text="Transfer Amount"
                    onAction="#transferMoney"
                    prefWidth="250"/>

            <Button text="Back to Dashboard"
                    onAction="#goBack"
                    prefWidth="250"/>

            <Label fx:id="lblMessage"/>

        </VBox>
    </center>

</BorderPane>