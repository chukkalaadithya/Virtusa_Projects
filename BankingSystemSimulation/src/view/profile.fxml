<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ProfileController"
            prefWidth="1200"
            prefHeight="700">

    <top>
        <HBox alignment="CENTER"
              style="-fx-padding: 20; -fx-background-color: #f5f5f5;">
            <Label text="Profile"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER"
              spacing="15"
              style="-fx-padding: 30;">

            <Label fx:id="lblFullName" />
            <Label fx:id="lblUsername" />
            <Label fx:id="lblMobile" />
            <Label fx:id="lblAddress" wrapText="true" />
            <Label fx:id="lblMessage" />

            <HBox alignment="CENTER" spacing="10">
                <Button text="Back"
                        onAction="#goBack"
                        prefWidth="120" />

                <Button text="Delete"
                        onAction="#deleteProfile"
                        prefWidth="120" />
            </HBox>

        </VBox>
    </center>

</BorderPane>