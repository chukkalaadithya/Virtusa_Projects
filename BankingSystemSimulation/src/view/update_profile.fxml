<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.UpdateController"
            prefWidth="1200"
            prefHeight="700">

    <top>
        <HBox alignment="CENTER"
              style="-fx-padding: 20; -fx-background-color: #f5f5f5;">
            <Label text="Update Profile"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;" />
        </HBox>
    </top>
    
    <center>
        <VBox alignment="CENTER"
              spacing="20"
              style="-fx-padding: 30;">

            <TextField fx:id="txtFullName"
                       promptText="Enter full name"
                       prefWidth="300" />

            <TextField fx:id="txtMobile"
                       promptText="Enter mobile number"
                       prefWidth="300" />

            <TextArea fx:id="txtAddress"
                      promptText="Enter address"
                      prefWidth="300"
                      prefHeight="80"
                      wrapText="true" />

            <Label fx:id="lblMessage"
                   style="-fx-font-size: 14px;" />

            <HBox alignment="CENTER" spacing="10">
                <Button text="Update"
                        onAction="#updateProfile"
                        prefWidth="120" />

                <Button text="Back"
                        onAction="#goBack"
                        prefWidth="120" />
            </HBox>

        </VBox>
    </center>

</BorderPane>